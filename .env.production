# Sovereign Privacy Gateway - Production Environment Configuration
# Copy this file to .env and configure for your environment

# ────────────────────────────────────────────────────────────────────────────
# Core Gateway Configuration
# ────────────────────────────────────────────────────────────────────────────

# Server ports
PORT=8080
DASHBOARD_PORT=8081

# Data storage
DATA_DIR=./data
DATABASE_PATH=/data/gateway.db

# Logging
LOG_LEVEL=info

# Privacy settings
STRICT_MODE=false
RETENTION_DAYS=30
MAX_CONCURRENCY=100

# ────────────────────────────────────────────────────────────────────────────
# AI Provider API Keys
# ────────────────────────────────────────────────────────────────────────────

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google AI API Key (get from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-google-ai-api-key-here

# ────────────────────────────────────────────────────────────────────────────
# Monitoring & Alerting
# ────────────────────────────────────────────────────────────────────────────

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=secure-admin-password-change-me

# Backup retention
BACKUP_RETENTION_DAYS=7

# ────────────────────────────────────────────────────────────────────────────
# SSL/TLS Configuration (for production with reverse proxy)
# ────────────────────────────────────────────────────────────────────────────

# Domain for SSL certificate
DOMAIN=your-domain.com

# Let's Encrypt email for certificate renewal
LETSENCRYPT_EMAIL=admin@your-domain.com

# ────────────────────────────────────────────────────────────────────────────
# Network & Security
# ────────────────────────────────────────────────────────────────────────────

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Rate limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# Session security
SESSION_SECRET=change-this-to-a-random-64-character-string-for-production

# ────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ────────────────────────────────────────────────────────────────────────────

# SQLite optimization
SQLITE_CACHE_SIZE=10000
SQLITE_MMAP_SIZE=268435456

# ────────────────────────────────────────────────────────────────────────────
# Docker Resource Limits
# ────────────────────────────────────────────────────────────────────────────

# Gateway memory limit
GATEWAY_MEMORY_LIMIT=1g

# Nginx memory limit
NGINX_MEMORY_LIMIT=256m

# ────────────────────────────────────────────────────────────────────────────
# Development Overrides (uncomment for development)
# ────────────────────────────────────────────────────────────────────────────

# LOG_LEVEL=debug
# STRICT_MODE=true
# DATA_DIR=./dev-data
