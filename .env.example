# Nonym Configuration
# Copy this file to .env and update with your values

# ==================== APPLICATION SETTINGS ====================

# Environment (development/production)
GATEWAY_TARGET=development
LOG_LEVEL=info

# Gateway Configuration
PORT=8080
STRICT_MODE=false

# ==================== DATABASE SETTINGS ====================

# PostgreSQL Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gateway
DB_USER=gateway
DB_PASSWORD=gateway_password
DB_SSL_MODE=disable

# ==================== REDIS SETTINGS ====================

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# ==================== AUTHENTICATION ====================

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session Secret (CHANGE IN PRODUCTION!)
SESSION_SECRET=your-super-secret-session-key

# ==================== SECURITY SETTINGS ====================

# Automatically log out after this period of inactivity (e.g. 1h, 30m, 2h)
SESSION_TIMEOUT=1h

# Lock account after this many consecutive failed login attempts
MAX_LOGIN_ATTEMPTS=5

# How long to keep the account locked after too many failed attempts (e.g. 15m, 1h)
LOCKOUT_DURATION=15m
