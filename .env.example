# Sovereign Privacy Gateway Configuration
# Copy this file to .env and update with your values

# ==================== APPLICATION SETTINGS ====================

# Environment (development/production)
GATEWAY_TARGET=development
LOG_LEVEL=debug

# Gateway Configuration
PORT=8080
DASHBOARD_PORT=8081
STRICT_MODE=false
RETENTION_DAYS=30
MAX_CONCURRENCY=100

# Data Directory (for volume mounts)
DATA_DIR=./data

# ==================== API KEYS ====================

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google AI API Key
GOOGLE_API_KEY=your-google-api-key-here

# Local LLM Configuration
LOCAL_LLM_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# ==================== DATABASE SETTINGS ====================

# PostgreSQL Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gateway
DB_USER=gateway
DB_PASSWORD=gateway_password
DB_SSL_MODE=disable

# Legacy SQLite (will be migrated)
DATABASE_PATH=/data/gateway.db

# ==================== AUTHENTICATION ====================

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session Secret (CHANGE IN PRODUCTION!)
SESSION_SECRET=your-super-secret-session-key

# ==================== MONITORING ====================

# Grafana Admin Credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
PROMETHEUS_RETENTION=15d

# ==================== RESOURCE LIMITS ====================

# Gateway Resource Limits
GATEWAY_MEMORY_LIMIT=1G
GATEWAY_CPU_LIMIT=1.0
GATEWAY_MEMORY_RESERVATION=512M
GATEWAY_CPU_RESERVATION=0.5

# ==================== BACKUP SETTINGS ====================

# Backup Retention (days)
BACKUP_RETENTION_DAYS=7

# ==================== NETWORK CONFIGURATION ====================

REQUEST_TIMEOUT=30s
RESPONSE_TIMEOUT=120s

# Security Settings
ALLOWED_ORIGINS=*
RATE_LIMIT_API=10
RATE_LIMIT_DASHBOARD=5
