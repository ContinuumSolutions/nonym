# Copy this file to .env and fill in the values before starting.

# Required — 32-byte hex key for AES-256-GCM credential encryption.
# Generate one with: openssl rand -hex 32
EK1_SECRET_KEY=

# Ollama settings (overridden to http://ollama:11434 inside Docker)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_KEEP_ALIVE=-1  # Keep models in memory indefinitely for faster responses

# How often the scheduler pulls signals and runs the brain pipeline
SYNC_INTERVAL_MINUTES=15

# Sentry error monitoring (optional — leave blank to disable)
SENTRY_DSN=
